# ============================================================
# ASK JL — Environment Variables
# ============================================================
# Copy this file: cp .env.example .env
# Fill in your values — NEVER commit .env to Git!
# ============================================================

# Anthropic API key — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Comma-separated allowed origins (no trailing slash)
ALLOWED_ORIGINS=https://www.jlsolutionsgroupe.com,https://jlsolutionsgroupe.com

# Set to "production" for live, "development" to allow all origins
NODE_ENV=production

# Formspree form ID — 8 characters from formspree.io/f/XXXXXXXX
FORMSPREE_ID=your-form-id-here

# Email to receive contact notifications
NOTIFY_EMAIL=info@jlsolutionsgroupe.com

# Server port (Railway sets this automatically)
PORT=3000
